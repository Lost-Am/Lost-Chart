local oppHits = 0
local bfHits = 0

function onCreatePost()

    setProperty('scoreTxt.visible', false)

    makeLuaText('healthCounter', '', 0, 0, getProperty('healthBar.y') - -25)
    setTextSize('healthCounter', 21) -- Tamaño que elegiste
    setObjectCamera('healthCounter', 'camHUD')
    addLuaText('healthCounter')
end

function opponentNoteHit(id, direction, noteType, isSustainNote)
    if not isSustainNote then
        oppHits = oppHits + 1
    end
end

function goodNoteHit(id, direction, noteType, isSustainNote)
    if not isSustainNote then
        bfHits = bfHits + 1
    end
end

function onUpdatePost(elapsed)

    local totalNotes = oppHits + bfHits

    local healthPercent = math.max(0, getProperty('health') * 50)

    local hpFormatted = string.format('%.2f', healthPercent)

    setTextString('healthCounter', 'Notes: ' .. oppHits .. ' + ' .. bfHits .. ' = ' .. totalNotes .. ' | HP: ' .. hpFormatted .. ' %')

    screenCenter('healthCounter', 'x')
end